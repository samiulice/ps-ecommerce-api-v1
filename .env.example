# =========================
# App Metadata
# =========================
APP_NAME=pse-api
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
FEATURE_AUTH=true

# =========================
# HTTP Server
# =========================
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# =========================
# JWT - Access Token
# =========================
JWT_ACCESS_SECRET=super-secret-access-key
JWT_ISSUER=pse-api
JWT_AUDIENCE=pse-users
JWT_ALGO=HS256
JWT_ACCESS_TTL=15m

# =========================
# JWT - Refresh Token
# =========================
JWT_REFRESH_SECRET=super-secret-refresh-key
JWT_REFRESH_TTL=168h   # 7 days

# =========================
# Database - Postgres
# =========================
DATABASE_URL=postgres://postgres:password@localhost:5432/pse?sslmode=disable
DATABASE_DEV_URL=postgres://postgres:password@localhost:5432/pse_dev?sslmode=disable

# =========================
# Cache - Redis
# =========================
REDIS_URL=localhost:6379
