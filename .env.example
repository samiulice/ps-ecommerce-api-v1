# =========================
# App Metadata
# =========================
APP_NAME=pse-api                  # Application name (used in logs, headers, metrics)
APP_ENV=development               # Application environment: development | staging | production
APP_DEBUG=true                   # Enable debug mode (detailed logs, stack traces)
APP_VERSION=1.0.0                # Current application version
FEATURE_AUTH=true                # Toggle authentication feature on/off

# =========================
# HTTP Server
# =========================
SERVER_PORT=8080                 # HTTP server listening port
SERVER_READ_TIMEOUT=15s          # Max duration to read the full request
SERVER_WRITE_TIMEOUT=15s         # Max duration before timing out response writes
SERVER_IDLE_TIMEOUT=60s          # Max time to keep idle connections open
MAX_REQUESTS=100                 # Maximum requests allowed per client within the time window
REQUEST_WINDOW=60s               # Time window for rate limiting (e.g., 100 requests per 60s)

# =========================
# JWT - Access Token
# =========================
JWT_ACCESS_SECRET=super-secret-access-key  # Secret key used to sign access tokens
JWT_ISSUER=pse-api                         # Token issuer (iss claim)
JWT_AUDIENCE=pse-users                    # Intended audience for the token (aud claim)
JWT_ALGO=HS256                            # JWT signing algorithm
JWT_ACCESS_TTL=15m                       # Access token expiration duration

# =========================
# JWT - Refresh Token
# =========================
JWT_REFRESH_SECRET=super-secret-refresh-key # Secret key used to sign refresh tokens
JWT_REFRESH_TTL=168h                        # Refresh token expiration duration (7 days)

# =========================
# Database - Postgres
# =========================
DATABASE_URL=postgres://postgres:password@localhost:5432/pse?sslmode=disable # Primary database connection string
DATABASE_DEV_URL=postgres://postgres:password@localhost:5432/pse_dev?sslmode=disable # Development database connection string

# =========================
# Cache - Redis
# =========================
REDIS_URL=localhost:6379                   # Redis server address (host:port)
